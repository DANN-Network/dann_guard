server {
    listen 80 default_server;
    listen [::]:80 default_server;
    server_name _;
    return 444;
}

server {
    listen 80;
    server_name __DOMAIN__;
    return 301 https://$server_name$request_uri;
}

server {
    listen 443 ssl http2;
    server_name __DOMAIN__;

    root /var/www/pterodactyl/public;
    index index.php;

    access_log /var/log/nginx/pterodactyl.app-access.log;
    error_log  /var/log/nginx/pterodactyl.app-error.log error;

    ssl_certificate /etc/letsencrypt/live/__DOMAIN__/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/__DOMAIN__/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    client_max_body_size 100m;
    client_body_timeout 120s;
    sendfile off;

    limit_conn conn_limit 50;
    limit_req zone=panel_limit burst=100 nodelay;
    limit_req_status 429;

    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "geolocation=(), microphone=(), camera=()" always;

    if ($bad_bot) { return 403; }
    if ($bad_referer) { return 403; }

    # Serve challenge page
    location = /__ddos_challenge {
        root /var/www/challenge;
        try_files /index.html =404;
    }

    # Handle challenge verification directly
    location = /__ddos_challenge/verify {
        set $device_id $cookie_device_id;
        if ($device_id = "") {
            set $device_id $connection$msec;
        }
        set $ip_hash "";
        if ($remote_addr ~ "^(\d+\.\d+)") {
            set $ip_hash $1;
        }
        
        add_header Set-Cookie "device_id=$device_id; Path=/; Max-Age=31536000; HttpOnly; Secure; SameSite=Lax";
        add_header Set-Cookie "ddos_clearance=$device_id:$ip_hash; Path=/; Max-Age=3600; HttpOnly; Secure; SameSite=Lax";
        
        if ($arg_redirect ~* "^/[a-zA-Z0-9/_.~\:-]*$") {
            return 302 $arg_redirect;
        }
        return 302 /;
    }

    # Admin protect page (served from challenge dir)
    location = /admin/protect {
        root /var/www/challenge;
        try_files /protect.php =404;
        fastcgi_pass unix:/run/php/php__PHP_VERSION__-fpm.sock;
        fastcgi_param SCRIPT_FILENAME /var/www/challenge/protect.php;
        include fastcgi_params;
        fastcgi_param HTTP_PROXY "";
    }

    # Admin routes
    location ~* ^/admin {
        try_files $uri $uri/ /index.php?$query_string;
    }

    # Main location with clearance check
    location / {
        if ($request_uri ~* "\.(css|js|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot|map)$") {
            set $skip_check 1;
        }
        if ($clearance_ok = 1) {
            set $skip_check 1;
        }
        if ($http_authorization ~* "^Bearer ") {
            set $skip_check 1;
        }
        if ($http_x_api_key != "") {
            set $skip_check 1;
        }
        if ($http_x_csrf_token != "") {
            set $skip_check 1;
        }
        if ($http_x_requested_with = "XMLHttpRequest") {
    if ($is_internal = 1) { set $skip_check 1; }
            set $skip_check 1;
        }
        if ($skip_check != 1) {
            return 302 /__ddos_challenge?redirect=$uri;
        }
        if (!-e $request_filename) {
            rewrite ^ /index.php last;
        }
    }

    location ~* ^/(login|register|password|api.*/auth) {
        limit_req zone=login_limit burst=10 nodelay;
        limit_req_status 429;
        try_files $uri $uri/ /index.php?$query_string;
    }

    location ~* ^/api/ {
        limit_req zone=api_limit burst=200 nodelay;
        limit_req_status 429;
        try_files $uri $uri/ /index.php?$query_string;
    }

    location ~ \.php$ {
        fastcgi_split_path_info ^(.+\.php)(/.+)$;
        fastcgi_pass unix:/run/php/php__PHP_VERSION__-fpm.sock;
        fastcgi_index index.php;
        include fastcgi_params;
        fastcgi_param PHP_VALUE "upload_max_filesize = 100M \n post_max_size=100M";
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        fastcgi_param HTTP_PROXY "";
        fastcgi_intercept_errors off;
        fastcgi_buffer_size 16k;
        fastcgi_buffers 4 16k;
        fastcgi_connect_timeout 300;
        fastcgi_send_timeout 300;
        fastcgi_read_timeout 300;
    }

    location ~ /\.ht { deny all; }
    location ~* /\.(env|git|htaccess|htpasswd|sql|bak|backup|log)$ { deny all; }
}
